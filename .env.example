# ============================================================
# Raven Multi-Bot Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Core Bot Settings ───────────────────────────────────────
# Your Mother Bot token from @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your Telegram user ID (owner with full admin access)
OWNER_ID=123456789

# Comma-separated list of admin Telegram user IDs
# Owner is always included automatically
ADMIN_IDS=123456789,987654321

# ─── Infrastructure ──────────────────────────────────────────
# Redis connection URL
REDIS_URL=redis://localhost:6379

# Database URL (SQLite for dev, PostgreSQL for production)
# SQLite:     sqlite+aiosqlite:///./raven.db
# PostgreSQL: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./raven.db

# Public base URL of your deployment (no trailing slash)
# Railway example: https://your-app.up.railway.app
BASE_URL=https://your-app.up.railway.app

# Port to listen on (Railway sets this automatically)
PORT=8000

# ─── Worker Configuration ────────────────────────────────────
# Number of concurrent worker slots (default: 8)
# Increase for more concurrent jobs (up to 100 with 32GB RAM)
WORKER_POOL_SIZE=8

# Maximum concurrent jobs across all users
MAX_CONCURRENT_JOBS=50

# ─── User Limits ─────────────────────────────────────────────
# Free tier daily credits
FREE_DAILY_CREDITS=10

# Max concurrent jobs per free user
FREE_MAX_CONCURRENT=2

# Max concurrent jobs per premium user
PREMIUM_MAX_CONCURRENT=5

# Cooldown between requests for free users (seconds)
FREE_COOLDOWN_SECONDS=30

# ─── File Settings ───────────────────────────────────────────
# Temporary file storage directory
TEMP_DIR=/tmp/raven_media

# Download link TTL in seconds (default: 20 minutes)
LINK_TTL_SECONDS=1200

# Maximum download link TTL (default: 30 minutes)
LINK_TTL_MAX_SECONDS=1800

# Minimum free disk space before rejecting jobs (GB)
MIN_FREE_DISK_GB=2.0

# ─── Security ────────────────────────────────────────────────
# Optional webhook secret token for additional security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# ─── Broadcast Settings ──────────────────────────────────────
# Number of messages per broadcast batch
BROADCAST_BATCH_SIZE=30

# Delay between broadcast batches (seconds)
BROADCAST_DELAY_SECONDS=1.0
